# .env Datei

# workspace: shared storage for the local repository
WORKSPACE=./workspace

# Docker container name that hosts the runnable workbench (backend or frontend)
WORKBENCH=workbench-backend
# Alternate workbench example for a frontend stack
#WORKBENCH=workbench-frontend

# Optional override for the agent stack (fallback derives from WORKBENCH)
#AGENT_STACK=backend

# database
ENCRYPTION_KEY=your_encryption_key_here

# GitHub Credentials
GITHUB_TOKEN=your_github_token_here

# LLM API keys (only set if you want to use them)
#MISTRAL_API_KEY=your_mistral_api_key_here
#GOOGLE_API_KEY=your_google_api_key_here
#OPENAI_API_KEY=your_openai_api_key_here
#OPENROUTER_API_KEY=your_openrouter_api_key_here
#ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama API key (only if a key is needed)
#OLLAMA_API_KEY=your_ollama_api_key_here
# Ollama base URL (only if you want to use Ollama not in a docker container)
#OLLAMA_BASE_URL=your_ollama_base_url_here

# enable or disable the mcp servers
ENABLE_MCP_SERVERS=True
