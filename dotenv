# .env Datei

# workspace: shared storage for the local repository
WORKSPACE=./local/workspace

# Docker container name that hosts the runnable workbench
WORKBENCH=cleankoda-workbench
# select docker socket if you start the cleankoda from the IDE with .vscode/launch.json you need DOCKER_HOST 
# if you use the docker socket in the standard linux system
#DOCKER_HOST="/var/run/docker.sock"
# if you use the docker socket from docker.desktop
#DOCKER_HOST="unix:///home/<user>/.docker/desktop/docker.sock"

# Optional override for the agent stack (fallback derives from WORKBENCH)
#AGENT_STACK=backend

# database
INSTANCE_DIR=./src/instance
ENCRYPTION_KEY=your_encryption_key_here

# enable or disable the mcp servers
ENABLE_MCP_SERVERS=True

# LLM calls per second limit the calls to the LLMs if you have a rate limit 
# (e.g. 0.8 to be save for Mistral with 1 call per second)
#LLM_CALLS_PER_SECOND=0.8

# Logging config file
LOGGING_CONFIG_FILE=logging.json

# Deployment
DEPLOYMENT_MODE=ON_PREMISE
# DEPLOYMENT_MODE=SERVERLESS